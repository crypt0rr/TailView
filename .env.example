# TailView will start after copying this file, but replace all REPLACE values
# before exposing it. Generate a setup token with: openssl rand -hex 32
APP_URL=http://localhost:8080
TAILVIEW_PORT=8080
TAILVIEW_IMAGE_NAMESPACE=ghcr.io/crypt0rr
TAILVIEW_VERSION=latest
TAILVIEW_SETUP_TOKEN=REPLACE-with-a-random-64-character-setup-token

# Generate with: openssl rand -base64 32 | tr '+/' '-_' | tr -d '\n'
# This zero-filled example decodes to 32 bytes but is public and MUST be replaced.
TAILVIEW_ENCRYPTION_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=

POSTGRES_DB=tailview
POSTGRES_USER=tailview
POSTGRES_PASSWORD=REPLACE-with-a-long-random-database-password
COOKIE_SECURE=false
DEMO_MODE=false

# Real tailnet mode. Disable DEMO_MODE before configuring these.
# Use "-" for the OAuth credential's tailnet, or the Tailnet ID shown under
# Tailscale Admin Console > General. Do not use the *.ts.net MagicDNS name.
TAILSCALE_TAILNET=-
TAILSCALE_OAUTH_CLIENT_ID=
TAILSCALE_OAUTH_CLIENT_SECRET=
TAILSCALE_API_TOKEN="" # Optional fallback; leave empty when OAuth is configured.

INVENTORY_INTERVAL_SECONDS=300
POSTURE_INTERVAL_SECONDS=300
SECURITY_SETTINGS_INTERVAL_SECONDS=900
POLICY_INTERVAL_SECONDS=300
FLOW_INTERVAL_SECONDS=60
AUDIT_INTERVAL_SECONDS=300
GOVERNANCE_INTERVAL_SECONDS=900
FINDINGS_INTERVAL_SECONDS=300
FINDINGS_RETENTION_DAYS=180
DEVICE_HISTORY_RETENTION_DAYS=365
TELEMETRY_RETENTION_DAYS=30
# Exact hostnames or CIDRs allowed for private webhook delivery. JSON list.
ALERT_WEBHOOK_HOST_ALLOWLIST=[]
FLOW_RETENTION_DAYS=7
FLOW_HOURLY_AGGREGATE_RETENTION_DAYS=90
FLOW_DAILY_AGGREGATE_RETENTION_DAYS=400
REPORT_ARTIFACT_RETENTION_DAYS=180
REPORT_GENERATION_TIMEOUT_SECONDS=120
REPORT_MAX_ARTIFACT_BYTES=20000000
REPORT_MAX_CONCURRENT_JOBS=1
OPERATIONS_JOB_RETENTION_DAYS=30
OPERATIONS_HISTORY_RETENTION_DAYS=180
OPERATIONS_BACKUP_MAX_AGE_HOURS=48
OPERATIONS_QUEUE_WARN_MINUTES=10
RAW_PAYLOAD_RETENTION_DAYS=7
EXPORT_ROW_LIMIT=10000
SAVED_VIEW_LIMIT=50
LOG_LEVEL=INFO
TRUSTED_PROXY_IPS=*
CORS_ORIGINS=[]

# Optional Caddy and local telemetry profile.
APP_DOMAIN=localhost
TAILVIEW_TELEMETRY_SECRET=
TELEMETRY_INTERVAL_SECONDS=60
TAILSCALE_SOCKET_PATH=/var/run/tailscale/tailscaled.sock
